{
  "manifest_version": 3,
  "name": "Shopping Assistant - Powered by UgUnlocked",
  "version": "1.0",
  "description": "Click to add the current product to Shopping Assistant",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Add to Shopping Assistant",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ]
}
